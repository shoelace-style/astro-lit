{
  "name": "@awesome.me/astro-lit",
  "version": "5.0.2",
  "description": "Use Lit components within Astro",
  "type": "module",
  "types": "./src/index.d.ts",
  "author": "Web Awesome",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shoelace.style/astro-lit.git"
  },
  "keywords": [
    "astro-integration",
    "astro-component",
    "renderer",
    "lit"
  ],
  "bugs": "https://github.com/shoelace-style/astro-lit/issues",
  "homepage": "https://github.com/shoelace-style/astro-lit",
  "exports": {
    ".": "./src/index.js",
    "./server.js": {
      "default": "./server.js",
      "types": "./server.d.ts"
    },
    "./dsd-polyfill.js": "./dsd-polyfill.js",
    "./src/client.js": "./src/client.js",
    "./hydration-support.js": "./hydration-support.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dsd-polyfill.js",
    "hydration-support.js",
    "server.js",
    "server.d.ts",
    "server-shim.js",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "npm run clean && tsc",
    "clean": "rimraf -g \"./src/**/*.d.ts\"",
    "prepublish": "npm run build",
    "deploy:patch": "npm version patch && npm publish && git push --follow-tags",
    "deploy:minor": "npm version minor && npm publish && git push --follow-tags",
    "deploy:major": "npm version major && npm publish && git push --follow-tags",
    "publish:beta": "npm publish --tag=beta && git push --follow-tags",
    "lint": "prettier --check .",
    "fix": "prettier --write ."
  },
  "dependencies": {
    "@lit-labs/ssr": "^4.1.0",
    "@lit-labs/ssr-client": "^1.1.8",
    "@lit-labs/ssr-dom-shim": "^1.6.0",
    "parse5": "^7.2.1"
  },
  "overrides": {},
  "devDependencies": {
    "@types/node": "^24.13.2",
    "astro": "^6.4.8",
    "cheerio": "1.0.0",
    "lit": "^3.2.1",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "sass": "^1.80.4",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@webcomponents/template-shadowroot": "^0.2.1",
    "lit": "^3.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
